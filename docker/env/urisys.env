APP_NAME=urisys-env-demo
APP_ENV=docker
APP_VERSION=0.1.0
URISYS_NODE_ID=docker-node-01
URISYS_RUNTIME_MODE=edge
FEATURE_FLAG_DEMO=off
APP_PUBLIC_GREETING=hello-from-public-prefix
# In production do not place real secrets in env files if Docker secrets are available.
# Dummy values are here only to make the compose demo self-contained.
OPENAI_API_KEY=sk-demo-not-real
